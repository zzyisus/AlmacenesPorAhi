<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlmacenesPorAhi.Views.LoginPage"
             Title="Login">
    <ContentPage.Resources>
        <Style TargetType="Entry">
            <Setter Property="BackgroundColor" Value="#F2F4F8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="HeightRequest" Value="48" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HeightRequest" Value="48" />
            <Setter Property="FontSize" Value="16" />
        </Style>
    </ContentPage.Resources>

    <VerticalStackLayout Padding="24" Spacing="18" HorizontalOptions="Center" VerticalOptions="Center">

        <Image Source="app_logo.png" HeightRequest="120" WidthRequest="120" HorizontalOptions="Center" />

        <Label Text="Bienvenido" FontSize="28" HorizontalOptions="Center" />
        <Label Text="Inicia sesión para continuar" FontSize="14" TextColor="#666" HorizontalOptions="Center" />

        <Entry x:Name="txtUsuario" Placeholder="Usuario" />
        <Entry x:Name="txtPassword" Placeholder="Contraseña" IsPassword="True" />

        <Button Text="Ingresar" Clicked="BtnIngresar_Clicked" BackgroundColor="#2D6CDF" TextColor="White" />

        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
            <Label Text="¿Olvidaste la contraseña?" FontSize="12" TextColor="#666" />
            <Button Text="Recuperar" FontSize="12" BackgroundColor="Transparent" TextColor="#2D6CDF" />
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>