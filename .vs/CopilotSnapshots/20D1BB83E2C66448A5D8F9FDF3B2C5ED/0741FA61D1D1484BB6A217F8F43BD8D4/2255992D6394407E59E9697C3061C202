<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlmacenesPorAhi.Views.InventarioPage"
             Title="Inventario">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Agregar" Clicked="OnAgregarClicked" />
        <ToolbarItem Text="Devoluciones" Clicked="Button_Clicked" />
    </ContentPage.ToolbarItems>

    <CollectionView x:Name="listaProductos" Margin="12" SelectionMode="Single">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="6" CornerRadius="10" HasShadow="True" Padding="8">
                    <Grid ColumnDefinitions="70, *" RowDefinitions="Auto,Auto">
                        <Image Grid.RowSpan="2" Grid.Column="0" Source="{Binding ImageUrl}" HeightRequest="70" WidthRequest="70" Aspect="AspectFill" />

                        <Label Grid.Column="1" Text="{Binding Nombre}" FontAttributes="Bold" FontSize="16" />
                        <Label Grid.Column="1" Grid.Row="1" Text="{Binding Description}" FontSize="12" TextColor="#666" />

                        <StackLayout Grid.Column="1" Grid.Row="0" Orientation="Horizontal" HorizontalOptions="End" Spacing="8">
                            <Label Text="{Binding Precio, StringFormat='₡{0:N0}'}" FontSize="14" />
                            <Frame BackgroundColor="#E9F5EA" Padding="6" CornerRadius="8">
                                <Label Text="{Binding Stock}" TextColor="#2D8A3E" />
                            </Frame>
                        </StackLayout>
                    </Grid>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>