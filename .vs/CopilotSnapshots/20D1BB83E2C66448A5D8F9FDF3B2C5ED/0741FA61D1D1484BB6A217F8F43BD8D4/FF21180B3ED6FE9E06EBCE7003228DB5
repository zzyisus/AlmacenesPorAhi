<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlmacenesPorAhi.Views.DevolucionPage"
             Title="Devoluciones">
    <VerticalStackLayout Padding="20" Spacing="12">

        <Label Text="Registrar Devolución" FontSize="22" />

        <HorizontalStackLayout Spacing="8">
            <Label Text="Producto ID" VerticalOptions="Center" WidthRequest="100" />
            <Entry x:Name="txtProducto" Placeholder="ID" Keyboard="Numeric" />
        </HorizontalStackLayout>

        <HorizontalStackLayout Spacing="8">
            <Label Text="Cantidad" VerticalOptions="Center" WidthRequest="100" />
            <Entry x:Name="txtCantidad" Placeholder="Cantidad" Keyboard="Numeric" />
        </HorizontalStackLayout>

        <Label Text="Motivo" />
        <Editor x:Name="txtMotivo" HeightRequest="100" Placeholder="Describe el motivo de la devolución" />

        <Button Text="Registrar" Clicked="Registrar_Clicked" BackgroundColor="#2D6CDF" TextColor="White" />

        <Label x:Name="lblFecha" TextColor="#666" FontSize="12" HorizontalOptions="End" />

    </VerticalStackLayout>
</ContentPage>