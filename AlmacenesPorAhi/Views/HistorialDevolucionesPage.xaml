<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlmacenesPorAhi.Views.HistorialDevolucionesPage"
             Title="Historial de Devoluciones"
             BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="Auto,*">

        <!-- Resumen -->
        <Frame Grid.Row="0" BackgroundColor="#1E3A5F" CornerRadius="0"
               HasShadow="False" Padding="20,14">
            <HorizontalStackLayout Spacing="32" HorizontalOptions="Center">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                    <Label x:Name="lblTotalDevoluciones" Text="0" FontSize="24"
                           FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                    <Label Text="Devoluciones" FontSize="11" TextColor="#93C5FD"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
                <BoxView WidthRequest="1" BackgroundColor="#374151" />
                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                    <Label x:Name="lblTotalReembolsado" Text="$0" FontSize="24"
                           FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                    <Label Text="Total reembolsado" FontSize="11" TextColor="#93C5FD"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Frame>

        <!-- Lista -->
        <CollectionView x:Name="listaHistorial" Grid.Row="1" Margin="12"
                        EmptyView="No hay devoluciones registradas aún.">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,4" CornerRadius="12" HasShadow="True"
                           Padding="14" BackgroundColor="White">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto,Auto,Auto">

                            <Label Grid.Column="0" Text="{Binding NombreProducto}"
                                   FontAttributes="Bold" FontSize="15" TextColor="#1E293B" />

                            <Label Grid.Column="1"
                                   Text="{Binding MontoReembolso, StringFormat='${0:N0}'}"
                                   FontAttributes="Bold" FontSize="15" TextColor="#1E3A5F"
                                   HorizontalOptions="End" />

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Cantidad, StringFormat='Cantidad: {0} uds'}"
                                   FontSize="12" TextColor="#64748B" />

                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Estado}" FontSize="11"
                                   TextColor="#16A34A" HorizontalOptions="End" />

                            <Label Grid.Row="2" Grid.ColumnSpan="2"
                                   Text="{Binding Motivo}" FontSize="12"
                                   TextColor="#94A3B8" LineBreakMode="TailTruncation" />

                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Fecha, StringFormat='{0:dd/MM HH:mm}'}"
                                   FontSize="11" TextColor="#CBD5E1" HorizontalOptions="End" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
